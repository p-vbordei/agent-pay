{
  "name": "@p-vbordei/agent-pay",
  "version": "0.1.0",
  "description": "L402 + DID-signed invoices: agent-to-agent Lightning payments",
  "author": "Vlad Bordei <bordeivlad@gmail.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/p-vbordei/agent-pay",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/p-vbordei/agent-pay.git"
  },
  "bugs": {
    "url": "https://github.com/p-vbordei/agent-pay/issues"
  },
  "keywords": [
    "lightning",
    "l402",
    "agents",
    "did",
    "payments",
    "bun",
    "hono",
    "ed25519"
  ],
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./client": "./src/client.ts",
    "./node/memory": "./src/memory-node.ts",
    "./node/lnd-rest": "./src/lnd-rest.ts"
  },
  "files": ["src", "README.md", "SPEC.md", "LICENSE", "CHANGELOG.md"],
  "scripts": {
    "test": "bun test",
    "test:integration": "AGENT_PAY_INTEGRATION=1 bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "conformance": "bun run conformance/run.ts",
    "demo": "bun run examples/demo.ts"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "bolt11": "^1.4.1",
    "canonicalize": "^2.0.0",
    "hono": "^4.6.0",
    "multiformats": "^13.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
